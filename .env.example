# ============================================================
# VisionPrice — API principal (Módulo de Usuarios)
# Copia este archivo a .env y rellena los valores.
# ============================================================

# --- App ---
APP_NAME=VisionPrice API
API_PREFIX=/api/v1
ENVIRONMENT=local            # local | production
ALLOWED_ORIGINS=*            # separados por coma; * = todos

# --- Base de datos ---
# Local (SQLite async):
DATABASE_URL=sqlite+aiosqlite:///./visionprice.db
#
# Producción con NEON: pega la "Connection string" de Neon TAL CUAL.
# La app la normaliza sola (cambia el driver a asyncpg y activa SSL).
# Ejemplo de cómo se ve la de Neon:
# DATABASE_URL=postgresql://usuario:password@ep-cool-name-123456.us-east-2.aws.neon.tech/visionprice?sslmode=require
#
# En Railway puedes referenciar la variable de Neon directamente:
# DATABASE_URL=${{ Neon.DATABASE_URL }}

# --- JWT (DEBE ser el MISMO secreto que el microservicio de Pagos) ---
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=1440

# --- Microservicio 2FA ---
TWO_FACTOR_BASE_URL=https://visionprice-2fa-production.up.railway.app
TWO_FACTOR_TIMEOUT=20

# --- Microservicio de Extracciones (audio -> JSON) ---
EXTRACTIONS_BASE_URL=https://visionprice-extractions-production.up.railway.app/api/v1
EXTRACTIONS_API_KEY=cambia-esto-por-el-MICROSERVICE_API_KEY

# --- Microservicio de Pagos (solo informativo: comparte JWT_SECRET) ---
PAYMENTS_BASE_URL=https://visionpricemicroserviciospagos-production.up.railway.app

# --- Webhooks ENTRANTES (los microservicios de ML y Pagos llaman de vuelta) ---
# Mismo valor que configures en esos microservicios como su API key de callback.
WEBHOOK_API_KEY=cambia-esto-por-una-api-key-interna
